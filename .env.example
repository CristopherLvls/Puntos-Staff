DISCORD_TOKEN=
DISCORD_GUILD_ID=

GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-2.5-flash

# SirgioBOT - solo lectura
MONGODB_READONLY_URI=
MONGODB_READONLY_DB=sirgiobot

# Cluster0 - escritura de evaluaciones
MONGODB_WRITE_URI=
MONGODB_WRITE_DB=insight_ia

# Roles que pueden usar /evaluar (IDs separados por coma)
ADMIN_ROLE_IDS=

# Colecciones de logs en SirgioBOT (separadas por coma)
MONGODB_LOGS_COLLECTIONS=auditlogs,modcases,ticketreviews,suggestions

# Campos extra donde SirgioBOT guarda el ID del staff (separados por coma)
# LOG_STAFF_ID_FIELDS=modUserId,actionBy

# Roles de staff — obtén los IDs con clic derecho en el rol (Modo desarrollador)
ROLE_HELPER_ID=1522373412880646288
ROLE_MODERATOR_ID=1510511672563994674
ROLE_TESTER_ID=1522373488990752869

# IDs extra de staff (opcional, separados por coma)
# STAFF_ROLE_IDS=

# Chat IA con staff (solo canales de la categoría indicada)
STAFF_CHAT_ENABLED=true
STAFF_CHAT_CATEGORY_ID=1222957745859465358
STAFF_CHAT_DEBOUNCE_SECONDS=4
STAFF_CHAT_MAX_PER_MINUTE=12
STAFF_CHAT_SYNC_KNOWLEDGE=true

# URL del README de SirgioBOT para sincronizar comandos
SIRGIOBOT_README_URL=https://raw.githubusercontent.com/CristopherAFK/SirgioBOT01/main/README.md
